<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HTML5 API Demo</title>

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: 'Segoe UI', sans-serif;
    }

    body {
        background: linear-gradient(135deg, #667eea, #764ba2);
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        color: white;
    }

    .container {
        width: 90%;
        max-width: 900px;
        padding: 25px;
        border-radius: 20px;
        background: rgba(255,255,255,0.1);
        backdrop-filter: blur(15px);
        box-shadow: 0 8px 32px rgba(0,0,0,0.3);
    }

    h2 {
        margin-bottom: 15px;
        text-align: center;
    }

    .section {
        margin: 20px 0;
        padding: 15px;
        border-radius: 15px;
        background: rgba(255,255,255,0.15);
    }

    button {
        padding: 10px 15px;
        border: none;
        border-radius: 10px;
        background: #00c6ff;
        color: white;
        cursor: pointer;
        transition: 0.3s;
    }

    button:hover {
        background: #0072ff;
    }

    /* Drag Drop */
    .drag-box, .drop-box {
        width: 120px;
        height: 120px;
        border-radius: 15px;
        display: inline-flex;
        justify-content: center;
        align-items: center;
        margin: 10px;
        font-weight: bold;
    }

    .drag-box {
        background: #ff7eb3;
        cursor: grab;
    }

    .drop-box {
        border: 2px dashed white;
    }

    input {
        padding: 10px;
        border-radius: 10px;
        border: none;
        margin-right: 10px;
    }

</style>
</head>

<body>

<div class="container">

    <h2>🚀 HTML5 API Demo</h2>

    <!-- Drag & Drop -->
    <div class="section">
        <h3>🎯 Drag & Drop</h3>

        <div id="dragItem" class="drag-box" draggable="true">
            Drag Me
        </div>

        <div id="dropArea" class="drop-box">
            Drop Here
        </div>
    </div>

    <!-- Geolocation -->
    <div class="section">
        <h3>📍 Geolocation</h3>
        <button onclick="getLocation()">Get Location</button>
        <p id="locationText"></p>
    </div>

    <!-- Web Storage -->
    <div class="section">
        <h3>💾 Local Storage</h3>
        <input type="text" id="nameInput" placeholder="Enter your name">
        <button onclick="saveData()">Save</button>
        <button onclick="loadData()">Load</button>
        <p id="displayName"></p>
    </div>

</div>

<script>
    // Drag & Drop
    const dragItem = document.getElementById("dragItem");
    const dropArea = document.getElementById("dropArea");

    dragItem.addEventListener("dragstart", (e) => {
        e.dataTransfer.setData("text", "dragItem");
    });

    dropArea.addEventListener("dragover", (e) => {
        e.preventDefault();
    });

    dropArea.addEventListener("drop", (e) => {
        e.preventDefault();
        dropArea.appendChild(dragItem);
    });

    // Geolocation
    function getLocation() {
        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(position => {
                document.getElementById("locationText").innerHTML =
                    "Latitude: " + position.coords.latitude +
                    "<br>Longitude: " + position.coords.longitude;
            });
        } else {
            alert("Geolocation not supported");
        }
    }

    // Local Storage
    function saveData() {
        const name = document.getElementById("nameInput").value;
        localStorage.setItem("username", name);
        alert("Saved!");
    }

    function loadData() {
        const name = localStorage.getItem("username");
        document.getElementById("displayName").innerText =
            name ? "Saved Name: " + name : "No data found";
    }
</script>

</body>
</html>
